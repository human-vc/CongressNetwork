%% Pipeline DAG for GATCongress replication
%% Render: mmdc -i pipeline_dag.mmd -o pipeline_dag.png

flowchart TD
    %% Raw data
    VV[Voteview raw CSV]
    MED[MEDSL general + primary returns]
    EP[HowTheyVote.eu + Hix-Noury-Roland EP data]
    TIGER[Census TIGER shapefiles]
    DEATH[house_deaths_1987_2025.csv]

    %% Processed
    NPZ[congress_*.npz]
    PANEL[member-Congress panel]
    DISTRICT[district_features.csv]

    %% Core analysis
    SPEC[spectral_analysis: Fiedler trajectory]
    BLI[bli_brute_force: per-member BLI]
    REG[bli_regression: GEE departure model]

    %% Theorems
    T1[bli_theorem_verification: Lemma 1 + Thm 1-3]
    T4[sbm_concentration_verify: Thm 4]
    CLT[bli_clt_verify: CLT under SBM]
    BENCH[sbm_benchmark_brev: 17,280-graph AUC benchmark]

    %% Causal identification
    DDD[cohort_ddd + staggered_did]
    HD[honest_did]
    MED2[mediation_analysis]
    DOI[death_in_office + interference_death]
    SEN[senate_analysis + sdid_bicameral]

    %% R comparators
    DIDR[did_comparator.R: 4 estimators]
    FECT[fect_placebo: parallel-trends placebo + equivalence]
    SPECR[specr_curve: spec curve]
    RDIT[rdit_close_margins]
    IV[iv_redistricting]
    INTERFLEX[interflex_gerrymandering]
    CW[causalweight_mediation]
    BF[bayes_factor_dfbetas]

    %% Robustness
    NCO[negative_controls]
    PLBO[placebo_loocv]
    NULLM[null_model_analysis]
    SENS[sensitivity_sweep]

    %% Cross-national
    EPBLI[ep_bli_all_terms]

    %% Figures
    FIGS[generate_figures]
    SKEL[skeleton_network]
    ALU[alluvial_coalitions]

    %% Output
    PDF[paper.pdf]

    %% Edges
    VV --> NPZ
    MED --> PANEL
    MED --> DISTRICT
    TIGER --> DISTRICT
    DEATH --> DOI
    EP --> EPBLI

    NPZ --> SPEC
    NPZ --> BLI
    BLI --> REG
    PANEL --> REG

    BLI --> T1
    BLI --> BENCH
    BENCH --> T4
    BENCH --> CLT

    PANEL --> DDD
    DDD --> HD
    PANEL --> MED2
    NPZ --> DOI
    NPZ --> SEN

    PANEL --> DIDR
    PANEL --> FECT
    PANEL --> SPECR
    PANEL --> RDIT
    PANEL --> IV
    DISTRICT --> INTERFLEX
    PANEL --> INTERFLEX
    PANEL --> CW
    PANEL --> BF

    PANEL --> NCO
    PANEL --> PLBO
    NPZ --> NULLM
    PANEL --> SENS

    REG --> FIGS
    SPEC --> FIGS
    BLI --> SKEL
    BLI --> ALU

    T1 --> PDF
    T4 --> PDF
    DDD --> PDF
    HD --> PDF
    MED2 --> PDF
    DOI --> PDF
    SEN --> PDF
    DIDR --> PDF
    FECT --> PDF
    SPECR --> PDF
    RDIT --> PDF
    IV --> PDF
    INTERFLEX --> PDF
    CW --> PDF
    BF --> PDF
    NCO --> PDF
    PLBO --> PDF
    SENS --> PDF
    EPBLI --> PDF
    FIGS --> PDF
    SKEL --> PDF
    ALU --> PDF

    classDef raw fill:#fde68a,stroke:#92400e
    classDef proc fill:#bfdbfe,stroke:#1e3a8a
    classDef analy fill:#bbf7d0,stroke:#14532d
    classDef robust fill:#fbcfe8,stroke:#831843
    classDef out fill:#e9d5ff,stroke:#581c87
    class VV,MED,EP,TIGER,DEATH raw
    class NPZ,PANEL,DISTRICT proc
    class SPEC,BLI,REG,T1,T4,CLT,BENCH,DDD,HD,MED2,DOI,SEN,DIDR,FECT,SPECR,RDIT,IV,INTERFLEX,CW,BF,EPBLI analy
    class NCO,PLBO,NULLM,SENS robust
    class FIGS,SKEL,ALU,PDF out
